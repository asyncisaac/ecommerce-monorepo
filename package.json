{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:full": "concurrently -n backend,frontend -c blue,green \"npm run dev\" \"npm run dev:frontend\"",
    "lint": "npm --prefix frontend run lint",
    "build": "tsc",
    "build:frontend": "npm --prefix frontend run build",
    "build:full": "npm run build && npm run build:frontend",
    "start": "node dist/server.js",
    "seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "promote:admin": "tsx scripts/promote-admin.ts",
    "test": "vitest run",
    "test:full": "npm run test && npm run lint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@tanstack/react-query": "^5.90.3",
    "@trpc/client": "^11.6.0",
    "@trpc/next": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.6.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "stripe": "^22.1.0",
    "superjson": "^2.2.2",
    "zod": "^4.1.12"
